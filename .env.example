# HoneyScan Environment Configuration
# Copy to .env and customize

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database
MONGO_URI=mongodb://honeyscan:honeyscan_secret@localhost:27017/honeyscan?authSource=admin

# Redis (Bull queue)
REDIS_URL=redis://localhost:6379

# JWT (future auth)
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars

# Optional Services (set to true to skip heavy deps)
SKIP_VM=true
SKIP_WIRESHARK=true
SKIP_SURICATA=true

# VirusTotal (get free key from virustotal.com)
VIRUSTOTAL_API_KEY=

# Docker uses container-internal URLs automatically

