# ── HoneyScan Environment Configuration ──
# Copy this to .env and fill in your values

# Server
NODE_ENV=development
PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/honeyscan

# Redis
REDIS_URL=redis://localhost:6379

# JWT (generate a long random string)
JWT_SECRET=change_this_to_a_very_long_random_secret_string_at_least_64_chars

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# ── VirtualBox Configuration ──
VBOX_VM_NAME=HoneyScan-Sandbox
VBOX_SNAPSHOT_NAME=CleanState
VBOX_VM_IP=192.168.56.101
# Set to 'true' for development without VirtualBox
SKIP_VM=true

# ── Wireshark/tshark Configuration ──
WIRESHARK_INTERFACE=vboxnet0
CAPTURE_DIR=./captures
# Set to 'true' for development without tshark
SKIP_WIRESHARK=true

# ── Suricata Configuration ──
SURICATA_EVE_LOG=/var/log/suricata/eve.json
# Set to 'true' for development without Suricata
SKIP_SURICATA=true

# ── Puppeteer ──
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false
# Uncomment if using system Chromium:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
